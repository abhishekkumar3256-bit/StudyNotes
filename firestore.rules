rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
              request.auth.token.email == 'abhishekkumar3256@gmail.com');
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- SCHEMAS ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.uid is string && data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 255 &&
             data.role in ['student', 'admin'] &&
             data.createdAt == request.time;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['title', 'link', 'class', 'subject', 'date', 'status', 'authorId']) &&
             data.keys().size() >= 7 &&
             data.title is string && data.title.size() <= 200 &&
             data.link is string && data.link.size() <= 1000 &&
             data.class is string && data.class.size() <= 50 &&
             data.subject is string && data.subject.size() <= 50 &&
             data.status in ['approved', 'pending'] &&
             (data.remark == null || (data.remark is string && data.remark.size() <= 500));
    }

    function isValidRequest(data) {
      return data.keys().hasAll(['title', 'link', 'class', 'subject', 'userId', 'userName', 'status', 'createdAt']) &&
             data.keys().size() >= 8 &&
             data.title is string && data.title.size() <= 200 &&
             data.link is string && data.link.size() <= 1000 &&
             data.userId == request.auth.uid &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt == request.time;
    }

    // --- COLLECTIONS ---

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['name']) &&
                      incoming().name is string && incoming().name.size() > 0;
      allow list: if isAdmin();
    }

    match /notes/{noteId} {
      allow list: if isSignedIn(); // Queries forced to status == approved by client
      allow get: if isSignedIn();
      allow create: if isAdmin() && isValidNote(incoming());
      allow update: if isAdmin() && isValidNote(incoming());
      allow delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidRequest(incoming());
      allow update: if isAdmin() && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                      incoming().status in ['approved', 'rejected'];
      allow delete: if isAdmin();
    }
    
    // Connectivity test path
    match /test/connection {
      allow get: if true;
    }
  }
}
